# ops/compose/.env — copy this file to .env (gitignored) and fill in real values.
# The .env file is read by docker compose at startup.

# ── Postgres ──────────────────────────────────────────────────────────────────

# Superuser password for the postgres container. Used only at init time.
# Not accessible by the application. Generate with: openssl rand -hex 32
POSTGRES_SUPERUSER_PASSWORD=change-me-strong-random-password

# Password for the comics_app Postgres role. Used by both the API (direct)
# and PgBouncer (via userlist.txt). Generate with: openssl rand -hex 32
COMICS_APP_PASSWORD=change-me-strong-random-password

# ── Connection strings (for reference; not read by compose itself) ─────────────

# Direct connection (used by the API container in Step 4 — bypasses PgBouncer):
#   DATABASE_URL=postgresql://comics_app:<COMICS_APP_PASSWORD>@postgres:5432/comics_gcd
#
# PgBouncer connection (used by future Vercel Next.js projects):
#   Must include ?pgbouncer=true to disable named prepared statements.
#   DATABASE_URL=postgresql://comics_app:<COMICS_APP_PASSWORD>@<droplet-ip>:6432/comics_gcd?sslmode=require&pgbouncer=true
#
# SSH-tunnel connection for Prisma migrations (bypasses PgBouncer):
#   First: ssh -L 15432:localhost:5432 rod@142.93.202.59
#   Then:  DATABASE_URL=postgresql://comics_app:<COMICS_APP_PASSWORD>@localhost:15432/comics_gcd

# ── PgBouncer TLS ─────────────────────────────────────────────────────────────
# Place TLS cert files at:
#   ops/compose/pgbouncer/tls/server.crt
#   ops/compose/pgbouncer/tls/server.key
# (both gitignored)
#
# Quick self-signed cert for testing (valid 10 years):
#   mkdir -p ops/compose/pgbouncer/tls
#   openssl req -x509 -newkey rsa:4096 -sha256 -days 3650 -nodes \
#     -keyout ops/compose/pgbouncer/tls/server.key \
#     -out    ops/compose/pgbouncer/tls/server.crt \
#     -subj "/CN=142.93.202.59"
#
# For a real cert (Let's Encrypt):
#   Use certbot with the standalone plugin or DNS challenge on the droplet.
#   Copy the resulting fullchain.pem → server.crt and privkey.pem → server.key.
