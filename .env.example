# PgBouncer connection (DigitalOcean droplet, requires TLS)
# sslmode=require enforces TLS; the certificate is Let's Encrypt auto-provisioned by Caddy
DATABASE_URL="postgresql://comics_app:password@api.dcdecade.com:6432/comics_gcd?sslmode=require"

# Port the API server listens on
PORT=4000

# Comma-separated list of allowed CORS origins
CORS_ORIGINS="https://your-app.vercel.app,http://localhost:3000"

# Node environment: development | production
NODE_ENV=development

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Comic Vine API (for cover image fetching script)
COMIC_VINE_API_KEY=

# Cloudinary (for cover image hosting)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
